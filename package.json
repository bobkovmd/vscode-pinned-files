{
  "name": "pinned-files",
  "displayName": "Pinned Files",
  "description": "Pin files to sidebar grouped by Project → Folder. Supports global/workspace storage scope, LRU auto-close, multi-root workspaces.",
  "version": "1.3.0",
  "publisher": "bobkovmd",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["pin", "files", "sidebar", "bookmark", "favorites"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [{"id":"pinnedFilesContainer","title":"Pinned Files","icon":"media/pin.svg"}]
    },
    "views": {
      "pinnedFilesContainer": [{"id":"pinnedFilesView","name":"Pinned Files"}]
    },
    "commands": [
      {"command":"pinnedFiles.pinActiveEditor","title":"Pin Current File","category":"Pinned Files"},
      {"command":"pinnedFiles.pin","title":"📌 Pin File","category":"Pinned Files"},
      {"command":"pinnedFiles.pinFromExplorer","title":"📌 Pin File","category":"Pinned Files"},
      {"command":"pinnedFiles.unpin","title":"Unpin","category":"Pinned Files","icon":"$(close)"},
      {"command":"pinnedFiles.unpinFolder","title":"Unpin All in Folder","category":"Pinned Files"},
      {"command":"pinnedFiles.unpinProject","title":"Unpin All in Project","category":"Pinned Files"},
      {"command":"pinnedFiles.clearAll","title":"Clear All Pinned Files","category":"Pinned Files","icon":"$(trash)"},
      {"command":"pinnedFiles.openFile","title":"Open File","category":"Pinned Files"},
      {"command":"pinnedFiles.revealInExplorer","title":"Reveal in Explorer","category":"Pinned Files"},
      {"command":"pinnedFiles.copyPath","title":"Copy Path","category":"Pinned Files"},
      {"command":"pinnedFiles.copyRelativePath","title":"Copy Relative Path","category":"Pinned Files"}
    ],
    "menus": {
      "view/title": [
        {"command":"pinnedFiles.clearAll","when":"view == pinnedFilesView","group":"navigation"}
      ],
      "view/item/context": [
        {"command":"pinnedFiles.unpin","when":"view == pinnedFilesView && viewItem == pinnedFile","group":"inline"},
        {"command":"pinnedFiles.revealInExplorer","when":"view == pinnedFilesView && viewItem == pinnedFile","group":"navigation@1"},
        {"command":"pinnedFiles.copyPath","when":"view == pinnedFilesView && viewItem == pinnedFile","group":"navigation@2"},
        {"command":"pinnedFiles.copyRelativePath","when":"view == pinnedFilesView && viewItem == pinnedFile","group":"navigation@3"},
        {"command":"pinnedFiles.unpin","when":"view == pinnedFilesView && viewItem == pinnedFile","group":"modification@1"},
        {"command":"pinnedFiles.unpinFolder","when":"view == pinnedFilesView && viewItem == pinnedFolder","group":"modification@1"},
        {"command":"pinnedFiles.unpinProject","when":"view == pinnedFilesView && viewItem == pinnedProject","group":"modification@1"}
      ],
      "explorer/context": [
        {"command":"pinnedFiles.pinFromExplorer","when":"!explorerResourceIsFolder","group":"navigation@100"}
      ],
      "editor/title/context": [
        {"command":"pinnedFiles.pin","group":"navigation@100"}
      ]
    },
    "configuration": {
      "title": "Pinned Files",
      "properties": {
        "pinnedFiles.storageScope": {
          "type": "string",
          "enum": ["global", "workspace"],
          "enumDescriptions": [
            "Global: pinned files shared across all workspaces (VS Code globalState)",
            "Workspace: pinned files specific to the current workspace folder (workspaceState)"
          ],
          "default": "global",
          "description": "Where to store pinned files. 'global' — one list for all workspaces; 'workspace' — separate list per workspace."
        },
        "pinnedFiles.groupByFolder": {"type":"boolean","default":true,"description":"Group pinned files by folder within each project"},
        "pinnedFiles.showRelativePath": {"type":"boolean","default":true,"description":"Show relative path as description (flat mode only)"},
        "pinnedFiles.sortOrder": {"type":"string","enum":["pinned","name","type"],"default":"pinned","description":"Sort order for files within each folder"},
        "pinnedFiles.maxOpenEditors": {"type":"number","default":0,"minimum":0,"maximum":50,"description":"Max open editor tabs (0 = disabled). Pinned files are never auto-closed."},
        "pinnedFiles.maxOpenEditorsNotify": {"type":"boolean","default":true,"description":"Show status bar message when a tab is auto-closed"}
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}